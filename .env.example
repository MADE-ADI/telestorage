# Telegram Bot Token dari @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID tempat file akan disimpan
# Bisa berupa: ID channel, ID group, atau ID user pribadi Anda
# Cara dapat Chat ID: lihat README.md
TELEGRAM_CHAT_ID=-1001234567890

# Telegram API credentials (dari https://my.telegram.org/apps)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
